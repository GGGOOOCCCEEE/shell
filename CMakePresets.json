{
  "version": 5,
  "configurePresets": [
    {
      "name": "wsl-debug",
      "displayName": "WSL Debug",
      "description": "Configure the project for a WSL debug build.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/wsl-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_STANDARD": "23",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "wsl-release",
      "displayName": "WSL Release",
      "description": "Configure the project for a WSL release build.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/wsl-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_STANDARD": "23",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "wsl-debug",
      "displayName": "WSL Debug",
      "configurePreset": "wsl-debug"
    },
    {
      "name": "wsl-release",
      "displayName": "WSL Release",
      "configurePreset": "wsl-release"
    }
  ]
}